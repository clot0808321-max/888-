<!doctype html><html lang="zh-Hant"><head><%- include('meta') %></head><body>
<div class="admin-layout"><%- include('partials-admin-nav') %>
<main class="admin-main excel-admin-page">
  <div class="topline excel-toolbar">
    <h1>訂單 #<%= order.id %></h1>
    <a class="btn ghost" href="/admin/orders">回訂單管理</a>
  </div>
  <div class="panel excel-card">
    <p><strong>姓名：</strong><%= order.customer_name %></p>
    <p><strong>電話：</strong><%= order.phone %></p>
    <p><strong>地址：</strong><%= order.address %></p>
    <p><strong>會員/備註：</strong><%= order.note || '無' %></p>
    <p><strong>下單時間：</strong><%= order.created_at %></p>
    <form action="/admin/orders/<%= order.id %>/status" method="post" class="excel-filter compact">
      <label>訂單狀態</label>
      <select name="status">
        <% ['新訂單','未付款','已付款','已出貨','已完成','已取消'].forEach(s => { %><option value="<%= s %>" <%= order.status===s?'selected':'' %>><%= s %></option><% }) %>
      </select>
      <button class="btn small">更新狀態</button>
    </form>
  </div>
  <h2>商品明細</h2>
  <div class="excel-table-wrap">
    <table class="excel-table"><tr><th>商品</th><th>類型</th><th>價格</th><th>數量</th><th>小計</th></tr>
    <% items.forEach(i => { %><tr><td><%= i.product_name %></td><td><%= stockLabel(i.stock_type) %></td><td>$<%= formatPrice(i.price) %></td><td><%= i.quantity %></td><td>$<%= formatPrice(i.subtotal) %></td></tr><% }) %>
    </table>
  </div>
  <h2>總金額：$<%= formatPrice(order.total) %></h2>
</main></div></body></html>
