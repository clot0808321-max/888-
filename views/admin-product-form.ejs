<!doctype html><html lang="zh-Hant"><head><%- include('meta') %></head><body>
<div class="admin-layout"><%- include('partials-admin-nav') %>
<main class="admin-main">
  <h1><%= product ? '修改商品' : '新增商品' %></h1>
  <form class="panel form-stack" method="post" enctype="multipart/form-data">
    <label>商品名稱<input name="name" required value="<%= product ? product.name : '' %>"></label>
    <label>價格<input type="number" name="price" min="0" step="0.01" inputmode="decimal" required value="<%= product ? formatPrice(product.price) : 0 %>" placeholder="例如 2.5 或 3.75"></label>

    <div class="stock-grid" style="display:grid; grid-template-columns:repeat(2,minmax(0,1fr)); gap:12px;">
      <label>散裝庫存<input type="number" name="loose_stock" min="0" step="1" required value="<%= product ? (product.loose_stock || 0) : 0 %>"></label>
      <label>整箱庫存<input type="number" name="box_stock" min="0" step="1" required value="<%= product ? (product.box_stock || 0) : 0 %>"></label>
    </div>

    <label>商品單位<select name="unit">
      <% ['件','罐','包','箱','瓶','袋','組','盒'].forEach(u => { %>
        <option value="<%= u %>" <%= (product ? (product.unit || '件') : '件') === u ? 'selected' : '' %>><%= u %></option>
      <% }) %>
    </select></label>
    <label>分類<select name="category_id"><% categories.forEach(c => { %><option value="<%= c.id %>" <%= product && product.category_id===c.id ? 'selected' : '' %>><%= c.name %></option><% }) %></select></label>
    <label>商品描述<textarea name="description" placeholder="可填規格、庫存說明，例如：散裝單罐、整箱12罐"><%= product ? product.description : '' %></textarea></label>
    <label>商品圖片<input type="file" name="image" accept="image/*"></label>
    <% if (product && product.image) { %><img class="preview" src="<%= product.image %>"><% } %>
    <label class="check"><input type="checkbox" name="is_active" <%= !product || product.is_active ? 'checked' : '' %>> 上架</label>
    <button class="btn">儲存</button>
  </form>
</main></div></body></html>
