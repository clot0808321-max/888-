<!doctype html><html lang="zh-Hant"><head><%- include('meta') %></head><body>
<div class="admin-layout"><%- include('partials-admin-nav') %>
<main class="admin-main">
  <div class="topline">
    <h1>商品庫存 Excel</h1>
    <div style="display:flex; gap:10px; flex-wrap:wrap;">
      <a class="btn" href="/admin/export/inventory">匯出庫存 Excel</a>
      <a class="btn ghost" href="/admin/products">回商品管理</a>
    </div>
  </div>

  <% if (saved) { %>
    <p class="success-msg">庫存已更新。</p>
  <% } %>

  <div class="admin-cards" style="margin-bottom:18px;">
    <div class="stat-card"><b>商品總數</b><strong><%= products.length %></strong></div>
    <div class="stat-card"><b>總庫存數量</b><strong><%= totalStock %></strong></div>
    <div class="stat-card"><b>低庫存商品</b><strong><%= lowStock %></strong><span class="muted">庫存 ≤ 5</span></div>
  </div>

  <p class="muted">此頁會連接商品資料與庫存數量。可直接修改散裝庫存 / 整箱庫存 / 單位，儲存後會同步到前台與下單扣庫存流程。</p>

  <form method="post" action="/admin/inventory/update">
    <table>
      <thead>
        <tr><th>ID</th><th>圖片</th><th>商品名稱</th><th>分類</th><th>價格 / 單位</th><th>散裝</th><th>整箱</th><th>總庫存</th><th>狀態</th><th>修改</th></tr>
      </thead>
      <tbody>
        <% products.forEach(p => { %>
          <tr>
            <td>#<%= p.id %><input type="hidden" name="product_id" value="<%= p.id %>"></td>
            <td><img class="thumb" src="<%= p.image || '/uploads/sample-1.svg' %>"></td>
            <td><%= p.name %></td>
            <td><%= p.category_name %></td>
            <td>
              $<%= formatPrice(p.price) %> /
              <select name="unit" style="width:78px; padding:6px; border-radius:8px; border:1px solid #ddd;">
                <% ['件','罐','包','箱','瓶','袋','組','盒'].forEach(u => { %>
                  <option value="<%= u %>" <%= (p.unit || '件') === u ? 'selected' : '' %>><%= u %></option>
                <% }) %>
              </select>
            </td>
            <td><input type="number" name="loose_stock" min="0" value="<%= p.loose_stock || 0 %>" style="width:90px; padding:8px; border-radius:8px; border:1px solid #ddd;"></td>
            <td><input type="number" name="box_stock" min="0" value="<%= p.box_stock || 0 %>" style="width:90px; padding:8px; border-radius:8px; border:1px solid #ddd;"></td>
            <td><%= p.stock || 0 %></td>
            <td><%= p.is_active ? '上架' : '下架' %></td>
            <td><a href="/admin/products/<%= p.id %>/edit">商品修改</a></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
    <div style="margin-top:16px;"><button class="btn" type="submit">儲存全部庫存</button></div>
  </form>
</main></div></body></html>
