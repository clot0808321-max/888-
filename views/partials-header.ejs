<header class="top-header bj-header">
  <div class="header-inner bj-header-inner">
    <a class="brand bj-brand" href="/" aria-label="回首頁">
      <img src="<%= siteSettings.logo_image %>" alt="<%= siteSettings.store_name %>">
    </a>
    <a class="tg-service" href="<%= siteSettings.service_link || siteSettings.tg_link %>" target="_blank" rel="noopener"><img src="<%= siteSettings.tg_icon %>" alt="TG客服"> <span>點我 👇 客服在線等</span></a>
    <a class="admin-entry" href="/admin">後台管理</a>
    <a class="header-cart" href="/cart" aria-label="購物車">
      🛒 <b><%= cartCount || 0 %></b>
    </a>
  </div>
</header>
