<!doctype html><html lang="zh-Hant"><head><%- include('meta') %></head><body>
<div class="admin-layout"><%- include('partials-admin-nav') %>
<main class="admin-main">
  <h1>網站設定</h1>
  <% if (saved) { %><div class="alert">網站設定已儲存。</div><% } %>
  <form class="panel form-stack settings-form" method="post" enctype="multipart/form-data">
    <label>商店名稱
      <input name="store_name" required value="<%= settings.store_name %>" placeholder="例如：888台灣商店">
    </label>

    <label>首頁封面圖
      <input type="file" name="hero_image" accept="image/*">
    </label>
    <% if (settings.hero_image) { %>
      <div class="setting-preview">
        <b>目前封面圖</b>
        <img src="<%= settings.hero_image %>" alt="目前封面圖">
      </div>
    <% } %>

    <label>LOGO
      <input type="file" name="logo_image" accept="image/*">
    </label>
    <% if (settings.logo_image) { %>
      <div class="setting-preview small">
        <b>目前 LOGO</b>
        <img src="<%= settings.logo_image %>" alt="目前 LOGO">
      </div>
    <% } %>

    <label>TG 圖示
      <input type="file" name="tg_icon" accept="image/*">
    </label>
    <% if (settings.tg_icon) { %>
      <div class="setting-preview icon">
        <b>目前 TG 圖示</b>
        <img src="<%= settings.tg_icon %>" alt="目前 TG 圖示">
      </div>
    <% } %>

    <label>TG 連結
      <input name="tg_link" value="<%= settings.tg_link %>" placeholder="https://t.me/TWSHOP888">
    </label>

    <label>客服連結
      <input name="service_link" value="<%= settings.service_link %>" placeholder="https://t.me/TWSHOP888">
    </label>

    <label>公告連結
      <input name="news_link" value="<%= settings.news_link %>" placeholder="https://t.me/TWSHOP888">
    </label>

    <label>公告文字
      <textarea name="announcement_text" rows="3" placeholder="公告文字"><%= settings.announcement_text %></textarea>
    </label>

    <label>跑馬燈文字
      <textarea name="marquee_text" rows="3" placeholder="跑馬燈文字"><%= settings.marquee_text %></textarea>
    </label>

    <label class="check"><input type="checkbox" name="marquee_enabled" <%= settings.marquee_enabled ? 'checked' : '' %>> 顯示跑馬燈</label>

    <button class="btn">儲存網站設定</button>
  </form>
</main></div></body></html>
