<!doctype html><html lang="zh-Hant"><head><%- include('meta') %></head><body>
<%- include('partials-header', {cartCount}) %>
<main class="container success">
  <h1>訂單已送出</h1>
  <p>您的訂單編號是：#<%= orderId %></p>
  <p>訂單已送出，請聯繫 Telegram 客服確認。</p>
<script>
setTimeout(() => {
    window.location.href = '<%= siteSettings.service_link || siteSettings.tg_link %>';
